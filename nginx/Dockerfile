FROM node:20-alpine AS frontend_builder
WORKDIR /app

COPY client/package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

COPY client/ ./

ARG VITE_API_URL=http://localhost
ARG VITE_WS_HOST=localhost
ARG VITE_WS_PORT=6001
ARG VITE_WSS_PORT=6001
ARG VITE_WS_SCHEME=ws
ARG VITE_GOOGLE_MAPS_API_KEY=
ARG VITE_OPENWEATHER_API_KEY=
ARG VITE_GEMINI_API_KEY=
ARG VITE_GROQ_CLOUD_API_KEY=

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_WS_HOST=${VITE_WS_HOST}
ENV VITE_WS_PORT=${VITE_WS_PORT}
ENV VITE_WSS_PORT=${VITE_WSS_PORT}
ENV VITE_WS_SCHEME=${VITE_WS_SCHEME}
ENV VITE_GOOGLE_MAPS_API_KEY=${VITE_GOOGLE_MAPS_API_KEY}
ENV VITE_OPENWEATHER_API_KEY=${VITE_OPENWEATHER_API_KEY}
ENV VITE_GEMINI_API_KEY=${VITE_GEMINI_API_KEY}
ENV VITE_GROQ_CLOUD_API_KEY=${VITE_GROQ_CLOUD_API_KEY}

RUN npm run build

FROM nginx:alpine
COPY nginx/default.prod.conf /etc/nginx/conf.d/default.conf
COPY --from=frontend_builder /app/dist /usr/share/nginx/html
