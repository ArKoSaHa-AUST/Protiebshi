APP_NAME=Protibeshi
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-railway-backend.up.railway.app
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
LOG_LEVEL=warning
QUEUE_CONNECTION=database

DB_CONNECTION=mysql
DB_HOST=<set-by-railway-or-your-db-provider>
DB_PORT=3306
DB_DATABASE=<set-by-railway-or-your-db-provider>
DB_USERNAME=<set-by-railway-or-your-db-provider>
DB_PASSWORD=<set-by-railway-or-your-db-provider>

BROADCAST_DRIVER=pusher
GEMINI_API_KEY=
PUSHER_APP_ID=local
PUSHER_APP_KEY=localkey
PUSHER_APP_SECRET=localsecret
PUSHER_APP_CLUSTER=mt1
# If you run websocket as a separate Railway service, set these to that service domain.
PUSHER_HOST=<your-websocket-service.up.railway.app>
PUSHER_PORT=443
PUSHER_SCHEME=https

# Optional runtime behavior
RUN_MIGRATIONS=true
RUN_ADMIN_SEEDER=true

# Fixed admin credentials used by admin signin
ADMIN_NAME=Protibeshi Admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123
