# Core app runtime
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
FRONTEND_URL=http://localhost
LOG_LEVEL=warning
QUEUE_CONNECTION=database
BROADCAST_DRIVER=pusher

# MySQL bootstrap
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=protibeshi_db
MYSQL_USER=protibeshi
MYSQL_PASSWORD=protibeshi

# Laravel DB connection
DB_DATABASE=protibeshi_db
DB_USERNAME=protibeshi
DB_PASSWORD=protibeshi
DB_WAIT_MAX_TRIES=60
RUN_DB_SEED=false

# Websocket/Pusher
PUSHER_APP_ID=local
PUSHER_APP_KEY=localkey
PUSHER_APP_SECRET=localsecret
PUSHER_APP_CLUSTER=mt1

# Public ports
HTTP_PORT=80
HTTPS_PORT=443

# TLS certificate mounts for Nginx
TLS_CERTS_PATH=./nginx/certs
TLS_ACME_PATH=./nginx/acme-challenge

# Frontend build-time variables (set to your public domain in real deployment)
VITE_API_URL=http://localhost
VITE_WS_HOST=localhost
VITE_WS_PORT=443
VITE_WSS_PORT=443
VITE_WS_SCHEME=wss

# Optional API keys for frontend features
VITE_GOOGLE_MAPS_API_KEY=
VITE_OPENWEATHER_API_KEY=
VITE_GEMINI_API_KEY=
